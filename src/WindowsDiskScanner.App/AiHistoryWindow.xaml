<Window x:Class="WindowsDiskScanner.App.AiHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 历史记录"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        Icon="Assets/app-icon.png"
        Background="#F3F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,18" Background="#14233C">
            <StackPanel>
                <TextBlock Foreground="White" FontSize="21" FontWeight="SemiBold" Text="AI 历史记录" />
                <TextBlock x:Name="SummaryText" Margin="0,4,0,0" Foreground="#AFC2E2" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="SelectAllCheckBox"
                      VerticalAlignment="Center"
                      Content="全选筛选结果"
                      IsThreeState="True"
                      Checked="SelectAllCheckBox_StateChanged"
                      Unchecked="SelectAllCheckBox_StateChanged"
                      Indeterminate="SelectAllCheckBox_StateChanged" />
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Margin="14,0,0,0"
                     TextChanged="SearchTextBox_TextChanged"
                     Style="{StaticResource AppTextBox}"
                     ToolTip="搜索标题、模型或内容" />
            <ComboBox x:Name="KindFilterComboBox"
                      Grid.Column="2"
                      Margin="12,0,0,0"
                      SelectionChanged="KindFilterComboBox_SelectionChanged"
                      Style="{StaticResource AppComboBox}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button x:Name="DeleteSelectedButton"
                    Grid.Column="3"
                    Margin="12,0,0,0"
                    Content="删除所选"
                    Click="DeleteSelectedButton_Click"
                    IsEnabled="False"
                    Style="{StaticResource AppDangerButton}" />
        </Grid>

        <Grid Grid.Row="2" Margin="20,0,20,16">
            <ListBox x:Name="HistoryList"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="HistoryList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,10" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15,13" Style="{StaticResource AppCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Column="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Padding="9,4" Background="#EAF1FD" CornerRadius="11">
                                            <TextBlock Foreground="#3566B0" FontSize="11" Text="{Binding Record.KindDisplayName}" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Margin="10,1,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#172742"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Record.Title}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBlock Margin="0,7,0,0"
                                               Foreground="#6B7B92"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Record.CreatedAtDisplay, Mode=OneWay}" />
                                        <Run Text="  ·  " />
                                        <Run Text="{Binding Record.ModelName, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <Button Content="查看"
                                            Click="OpenHistoryButton_Click"
                                            Style="{StaticResource AppButton}" />
                                    <Button Margin="8,0,0,0"
                                            Content="删除"
                                            Click="DeleteHistoryButton_Click"
                                            Style="{StaticResource AppDangerButton}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" Foreground="#93A2B7" FontSize="38" Text="◇" />
                <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="#5D6E86" FontSize="15" FontWeight="SemiBold" Text="暂无历史记录" />
                <TextBlock Margin="0,4,0,0" Foreground="#8A97A9" Text="完成 AI 报告或询问后可在这里回看" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Padding="20,13" Background="White" BorderBrush="#E1E7EF" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="#6A7890"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                <Button Grid.Column="1" Content="关闭" Click="CloseButton_Click" Style="{StaticResource AppPrimaryButton}" />
            </Grid>
        </Border>
    </Grid>
</Window>
