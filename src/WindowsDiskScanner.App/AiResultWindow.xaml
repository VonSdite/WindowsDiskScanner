<Window x:Class="WindowsDiskScanner.App.AiResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
        Title="AI 分析"
        Width="850"
        Height="700"
        MinWidth="620"
        MinHeight="480"
        Icon="Assets/app-icon.png"
        Background="#F3F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,17" Background="#14233C">
            <StackPanel>
                <TextBlock x:Name="TitleText" Foreground="White" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ModelText" Margin="0,4,0,0" Foreground="#AFC2E2" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Expander x:Name="ReasoningExpander"
                      Margin="0,0,0,12"
                      IsExpanded="False"
                      Visibility="Collapsed">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#697991" FontSize="12" FontWeight="SemiBold" Text="思考过程" />
                        <TextBlock Margin="6,0,0,0" Foreground="#9AA6B8" FontSize="11" Text="点击展开" />
                    </StackPanel>
                </Expander.Header>
                <Border Margin="0,8,0,0"
                        MaxHeight="190"
                        Padding="12,10"
                        Background="#F7F9FC"
                        BorderBrush="#E2E8F1"
                        BorderThickness="1"
                        CornerRadius="7">
                    <md:MarkdownScrollViewer x:Name="ReasoningViewer"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#7B8799"
                                             FontFamily="Segoe UI, Microsoft YaHei UI"
                                             FontSize="12"
                                             MarkdownStyleName="Compact"
                                             VerticalScrollBarVisibility="Auto" />
                </Border>
            </Expander>

            <Border Grid.Row="1" Padding="16" Style="{StaticResource AppCard}">
                <Grid>
                    <md:MarkdownScrollViewer x:Name="ContentViewer"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#263751"
                                             FontFamily="Segoe UI, Microsoft YaHei UI"
                                             FontSize="14"
                                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="ThinkingPlaceholder"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#9AA6B8"
                               FontSize="14"
                               IsHitTestVisible="False"
                               Text="思考中…" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="FollowUpPanel"
                Grid.Row="2"
                Padding="20,12"
                Background="White"
                BorderBrush="#E1E7EF"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <TextBox x:Name="FollowUpTextBox"
                             MinHeight="40"
                             MaxHeight="88"
                             AcceptsReturn="True"
                             IsEnabled="False"
                             KeyDown="FollowUpTextBox_KeyDown"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource AppTextBox}" />
                    <TextBlock x:Name="FollowUpPlaceholder"
                               Margin="11,0"
                               VerticalAlignment="Center"
                               Foreground="#9AA6B8"
                               IsHitTestVisible="False"
                               Text="当前回答完成后可继续追问"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{Binding Text, ElementName=FollowUpTextBox, Converter={StaticResource AppEmptyStringToVisibilityConverter}}" />
                </Grid>
                <Button x:Name="FollowUpButton"
                        Grid.Column="1"
                        MinWidth="76"
                        Margin="10,0,0,0"
                        Content="追问"
                        Click="FollowUpButton_Click"
                        IsEnabled="False"
                        Style="{StaticResource AppPrimaryButton}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Padding="20,14" Background="White" BorderBrush="#E1E7EF" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="CopyButton" Margin="0,0,10,0" Content="复制内容" Click="CopyButton_Click" IsEnabled="False" Style="{StaticResource AppButton}" />
                <Button Content="关闭" IsCancel="True" Click="CloseButton_Click" Style="{StaticResource AppPrimaryButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
