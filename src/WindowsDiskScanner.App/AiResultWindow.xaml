<Window x:Class="WindowsDiskScanner.App.AiResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 分析"
        Width="1100"
        Height="760"
        MinWidth="760"
        MinHeight="520"
        Icon="Assets/app-icon.png"
        Background="#F3F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,17" Background="#14233C">
            <StackPanel>
                <TextBlock x:Name="TitleText" Foreground="White" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ModelText" Margin="0,4,0,0" Foreground="#AFC2E2" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Border Padding="10" Background="#F8FAFC" Style="{StaticResource AppCard}">
                <ScrollViewer x:Name="ConversationScrollViewer"
                              Focusable="False"
                              FocusVisualStyle="{x:Null}"
                              HorizontalContentAlignment="Stretch"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ConversationPanel" />
                </ScrollViewer>
            </Border>
        </Grid>

        <Border x:Name="FollowUpPanel"
                Grid.Row="2"
                Padding="20,12"
                Background="White"
                BorderBrush="#E1E7EF"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <TextBox x:Name="FollowUpTextBox"
                             MinHeight="40"
                             MaxHeight="88"
                             AcceptsReturn="True"
                             IsEnabled="False"
                             PreviewKeyDown="FollowUpTextBox_KeyDown"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource AppTextBox}" />
                    <TextBlock x:Name="FollowUpPlaceholder"
                               Margin="11,0"
                               VerticalAlignment="Center"
                               Foreground="#9AA6B8"
                               IsHitTestVisible="False"
                               Text="当前回答完成后可继续追问"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{Binding Text, ElementName=FollowUpTextBox, Converter={StaticResource AppEmptyStringToVisibilityConverter}}" />
                </Grid>
                <Button x:Name="FollowUpButton"
                        Grid.Column="1"
                        MinWidth="76"
                        Margin="10,0,0,0"
                        Content="追问"
                        Click="FollowUpButton_Click"
                        IsEnabled="False"
                        Style="{StaticResource AppPrimaryButton}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Padding="20,14" Background="White" BorderBrush="#E1E7EF" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="CopyButton" Margin="0,0,10,0" Content="复制内容" Click="CopyButton_Click" IsEnabled="False" Style="{StaticResource AppButton}" />
                <Button Content="关闭" IsCancel="True" Click="CloseButton_Click" Style="{StaticResource AppPrimaryButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
