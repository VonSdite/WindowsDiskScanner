<Window x:Class="WindowsDiskScanner.App.ProviderManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLM Provider 管理"
        Width="900"
        Height="650"
        MinWidth="720"
        MinHeight="480"
        Icon="Assets/app-icon.png"
        Background="#F3F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid x:Name="ProviderListPage">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,18" Background="#14233C">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="White" FontSize="21" FontWeight="SemiBold" Text="LLM Provider" />
                    <TextBlock Margin="0,4,0,0" Foreground="#AFC2E2" Text="管理 OpenAI Chat 兼容接口" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="新增 Provider"
                        Click="AddProviderButton_Click"
                        Style="{StaticResource AppPrimaryButton}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22,18">
            <ListBox x:Name="ProvidersList"
                     AllowDrop="True"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     PreviewMouseLeftButtonDown="ProvidersList_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="ProvidersList_PreviewMouseMove"
                     DragOver="ProvidersList_DragOver"
                     DragLeave="ProvidersList_DragLeave"
                     Drop="ProvidersList_Drop"
                     MouseDoubleClick="ProvidersList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,10" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15,13" Style="{StaticResource AppCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#8A98AC"
                                           FontSize="18"
                                           Text="⠿"
                                           ToolTip="拖动调整 Provider 顺序" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Foreground="#172742"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#75839A"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="12"
                                               Text="{Binding ApiUrl}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border Grid.Column="2"
                                        Margin="14,0"
                                        Padding="10,5"
                                        VerticalAlignment="Center"
                                        Background="#EEF3FB"
                                        CornerRadius="12">
                                    <TextBlock Foreground="#526B91">
                                        <Run Text="{Binding Models.Count, Mode=OneWay}" />
                                        <Run Text=" 个模型" />
                                    </TextBlock>
                                </Border>
                                <Button Grid.Column="3"
                                        Margin="0,0,8,0"
                                        Content="编辑"
                                        Click="EditProviderButton_Click"
                                        Style="{StaticResource AppButton}" />
                                <Button Grid.Column="4"
                                        Content="删除"
                                        Click="DeleteProviderButton_Click"
                                        Style="{StaticResource AppDangerButton}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" Foreground="#93A2B7" FontSize="38" Text="◇" />
                <TextBlock Margin="0,10,0,0" Foreground="#5D6E86" FontSize="15" FontWeight="SemiBold" Text="尚未配置 Provider" />
                <TextBlock Margin="0,4,0,0" Foreground="#8A97A9" Text="新增一个 OpenAI Chat 兼容接口后即可使用 AI 功能" />
            </StackPanel>
        </Grid>

            <Border Grid.Row="2" Padding="22,12" Background="White" BorderBrush="#E1E7EF" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Foreground="#6A7890" Text="拖动 Provider 可以调整调用顺序。" />
            </Border>
        </Grid>

        <ContentControl x:Name="EditorHost" Visibility="Collapsed" />
    </Grid>
</Window>
