<UserControl x:Class="WindowsDiskScanner.App.ProviderEditorDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F6FA"
             FontFamily="Segoe UI, Microsoft YaHei UI"
             PreviewKeyDown="ProviderEditor_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,17" Background="#14233C">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Width="38"
                        Height="38"
                        MinHeight="38"
                        Margin="0,0,12,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Background="#243A5B"
                        Click="CancelButton_Click"
                        Style="{StaticResource AppButton}"
                        ToolTip="返回 Provider 列表">
                    <Viewbox Width="19" Height="19">
                        <Path Fill="White"
                              Data="M20,11 L7.83,11 L13.42,5.41 L12,4 L4,12 L12,20 L13.41,18.59 L7.83,13 L20,13 Z" />
                    </Viewbox>
                </Button>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0" Foreground="#AFC2E2" Text="仅支持 OpenAI Chat 兼容上游" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,18">
                <Border Padding="18" Style="{StaticResource AppCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Style="{StaticResource AppFieldLabel}">
                                <Run Text="Provider 名称" />
                                <Run Foreground="#D14343" Text=" *" />
                            </TextBlock>
                            <Grid>
                                <TextBox x:Name="ProviderNameTextBox"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="RequiredTextBox_TextChanged"
                                         Style="{StaticResource AppTextBox}" />
                                <TextBlock Text="例如：OpenAI"
                                           Visibility="{Binding Text, ElementName=ProviderNameTextBox, Converter={StaticResource AppEmptyStringToVisibilityConverter}}"
                                           Style="{StaticResource AppInputPlaceholder}" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Style="{StaticResource AppFieldLabel}" Text="API Key" />
                            <Grid>
                                <PasswordBox x:Name="ApiKeyBox"
                                             PasswordChanged="ApiKeyBox_PasswordChanged"
                                             Style="{StaticResource AppPasswordBox}" />
                                <TextBlock x:Name="ApiKeyPlaceholder"
                                           Text="例如：sk-...（可选）"
                                           Style="{StaticResource AppInputPlaceholder}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,15,0,0">
                            <TextBlock Style="{StaticResource AppFieldLabel}">
                                <Run Text="API 地址" />
                                <Run Foreground="#D14343" Text=" *" />
                            </TextBlock>
                            <Grid>
                                <TextBox x:Name="ApiUrlTextBox"
                                         Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="RequiredTextBox_TextChanged"
                                         FontFamily="Cascadia Mono, Consolas"
                                         Style="{StaticResource AppTextBox}" />
                                <TextBlock Text="例如：https://api.openai.com/v1"
                                           FontFamily="Cascadia Mono, Consolas"
                                           Visibility="{Binding Text, ElementName=ApiUrlTextBox, Converter={StaticResource AppEmptyStringToVisibilityConverter}}"
                                           Style="{StaticResource AppInputPlaceholder}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,15,0,0">
                            <TextBlock Style="{StaticResource AppFieldLabel}" Text="上游出站代理" />
                            <ComboBox x:Name="ProxyModeComboBox"
                                      SelectedValuePath="Mode"
                                      SelectionChanged="ProxyModeComboBox_SelectionChanged"
                                      Style="{StaticResource AppComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="CustomProxyPanel" Grid.Row="2" Grid.Column="2" Margin="0,15,0,0">
                            <TextBlock Style="{StaticResource AppFieldLabel}">
                                <Run Text="自定义代理地址" />
                                <Run Foreground="#D14343" Text=" *" />
                            </TextBlock>
                            <Grid>
                                <TextBox x:Name="CustomProxyTextBox"
                                         Text="{Binding CustomProxy, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="RequiredTextBox_TextChanged"
                                         FontFamily="Cascadia Mono, Consolas"
                                         Style="{StaticResource AppTextBox}" />
                                <TextBlock Text="例如：http://127.0.0.1:7890"
                                           FontFamily="Cascadia Mono, Consolas"
                                           Visibility="{Binding Text, ElementName=CustomProxyTextBox, Converter={StaticResource AppEmptyStringToVisibilityConverter}}"
                                           Style="{StaticResource AppInputPlaceholder}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0" Padding="18" Style="{StaticResource AppCard}">
                    <CheckBox x:Name="VerifySslCheckBox"
                              VerticalAlignment="Center"
                              Content="校验上游 SSL 证书"
                              Foreground="#33445F"
                              FontWeight="SemiBold" />
                </Border>

                <Border Margin="0,14,0,0" Padding="18" Style="{StaticResource AppCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="#172742" FontSize="16" FontWeight="SemiBold" Text="模型列表" />
                                <TextBlock Margin="0,3,0,0" Foreground="#7A879B" Text="拖动模型调整顺序，测试结果仅用于当前编辑会话。" />
                            </StackPanel>
                            <Button x:Name="FetchModelsButton" Grid.Column="1" Margin="8,0,0,0" Content="拉取模型" Click="FetchModelsButton_Click" Style="{StaticResource AppButton}" />
                            <Button x:Name="TestModelsButton" Grid.Column="2" Margin="8,0,0,0" Content="测试" Click="TestModelsButton_Click" Style="{StaticResource AppButton}" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,14,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <TextBox x:Name="NewModelTextBox"
                                         KeyDown="NewModelTextBox_KeyDown"
                                         Style="{StaticResource AppTextBox}" />
                                <TextBlock Text="例如：gpt-4.1-mini"
                                           Visibility="{Binding Text, ElementName=NewModelTextBox, Converter={StaticResource AppEmptyStringToVisibilityConverter}}"
                                           Style="{StaticResource AppInputPlaceholder}" />
                            </Grid>
                            <Button x:Name="AddModelButton" Grid.Column="1" Margin="8,0,0,0" Content="添加模型" Click="AddModelButton_Click" Style="{StaticResource AppPrimaryButton}" />
                        </Grid>

                        <ListBox x:Name="ModelsList"
                                 Grid.Row="2"
                                 Height="260"
                                 ItemsSource="{Binding Models}"
                                 SelectionMode="Extended"
                                 AllowDrop="True"
                                 HorizontalContentAlignment="Stretch"
                                 BorderBrush="#E1E7EF"
                                 BorderThickness="1"
                                 Background="#FBFCFE"
                                 PreviewMouseLeftButtonDown="ModelsList_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="ModelsList_PreviewMouseMove"
                                 DragOver="ModelsList_DragOver"
                                 DragLeave="ModelsList_DragLeave"
                                 Drop="ModelsList_Drop">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderBrush" Value="#E9EDF3" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="9,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Margin="2,0,0,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#8A98AC" FontSize="17" Text="⠿" />
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Cascadia Mono, Consolas"
                                                 Style="{StaticResource AppTextBox}" />
                                        <TextBlock Grid.Column="3"
                                                   MaxWidth="180"
                                                   Margin="12,0,4,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#526B91"
                                                   Text="{Binding TestStatus}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding TestMessage}" />
                                        <StackPanel Grid.Column="4" Margin="8,0,0,0" Orientation="Horizontal">
                                            <Button MinHeight="30"
                                                    Padding="10,5"
                                                    Content="测试"
                                                    Click="TestModelButton_Click"
                                                    Style="{StaticResource AppButton}" />
                                            <Button MinHeight="30"
                                                    Margin="6,0,0,0"
                                                    Padding="10,5"
                                                    Content="删除"
                                                    Click="RemoveModelButton_Click"
                                                    Style="{StaticResource AppDangerButton}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="20,14" Background="White" BorderBrush="#E1E7EF" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#6A7890" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Margin="0,0,10,0" Content="取消" Click="CancelButton_Click" Style="{StaticResource AppButton}" />
                    <Button x:Name="SaveButton" Content="保存 Provider" Click="SaveButton_Click" Style="{StaticResource AppPrimaryButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
