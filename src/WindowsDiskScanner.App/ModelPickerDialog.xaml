<Window x:Class="WindowsDiskScanner.App.ModelPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择拉取模型"
        Width="620"
        Height="680"
        MinWidth="500"
        MinHeight="480"
        Icon="Assets/app-icon.png"
        Background="#F3F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="22,17" Background="#14233C">
            <StackPanel>
                <TextBlock Foreground="White" FontSize="19" FontWeight="SemiBold" Text="选择模型" />
                <TextBlock x:Name="SummaryText" Margin="0,4,0,0" Foreground="#AFC2E2" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20,16,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="SelectAllCheckBox"
                      Margin="10,0,0,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      ToolTip="全选过滤后的模型"
                      IsThreeState="True"
                      Checked="SelectAllCheckBox_StateChanged"
                      Unchecked="SelectAllCheckBox_StateChanged"
                      Indeterminate="SelectAllCheckBox_StateChanged" />
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     TextChanged="SearchTextBox_TextChanged"
                     Style="{StaticResource AppTextBox}"
                     ToolTip="搜索模型" />
        </Grid>

        <ListBox x:Name="ModelsList"
                 Grid.Row="2"
                 Margin="20,0"
                 HorizontalContentAlignment="Stretch"
                 BorderBrush="#E1E7EF"
                 BorderThickness="1"
                 Background="White">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="BorderBrush" Value="#EDF1F6" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Margin="8,0,0,0"
                              Padding="12,9"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Center"
                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Margin="10,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Cascadia Mono, Consolas"
                                       Foreground="#24344F"
                                       Text="{Binding Name}" />
                            <Border Grid.Column="1"
                                    Padding="9,4"
                                    Background="#EAF1FD"
                                    CornerRadius="10"
                                    Visibility="{Binding IsExisting, Converter={StaticResource AppBooleanToVisibilityConverter}}">
                                <TextBlock Foreground="#3566B0" FontSize="11" Text="已在清单" />
                            </Border>
                        </Grid>
                    </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="3" Padding="20,14" Background="White" BorderBrush="#E1E7EF" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,10,0" Content="取消" IsCancel="True" Style="{StaticResource AppButton}" />
                <Button Content="添加所选模型" Click="ConfirmButton_Click" Style="{StaticResource AppPrimaryButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
