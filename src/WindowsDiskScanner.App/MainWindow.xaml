<Window x:Class="WindowsDiskScanner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowsDiskScanner.App"
        Title="Windows 磁盘空间扫描器"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        Icon="Assets/app-icon.png"
        Background="#F3F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        Closing="Window_Closing">
    <Window.Resources>
        <local:ByteSizeConverter x:Key="ByteSizeConverter" />
        <local:AccessOpacityConverter x:Key="AccessOpacityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2F6FED" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#225DCE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E9EFFA" />
            <Setter Property="Foreground" Value="#244777" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="BorderBrush" Value="#E5EAF1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="43" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="BorderBrush" Value="#E4E9F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#697991" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="RightGridHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <Style x:Key="CenterGridHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="RowContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE4EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style x:Key="RowContextMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#24344F" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="GridRow" TargetType="DataGridRow">
            <EventSetter Event="MouseDoubleClick" Handler="DirectoryRow_MouseDoubleClick" />
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="DirectoryRow_PreviewMouseRightButtonDown" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#EEF2F7" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Opacity" Value="{Binding Node.IsAccessible, Converter={StaticResource AccessOpacityConverter}}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F7FC" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF1FD" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#14233C" Padding="28,21">
            <StackPanel>
                <TextBlock Foreground="White" FontSize="24" FontWeight="SemiBold" Text="Windows 磁盘空间扫描器" />
                <TextBlock Margin="0,5,0,0" Foreground="#AFC2E2" Text="快速定位系统目录中的空间占用" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="24,20,24,0" Padding="14" Background="White" BorderBrush="#E3E9F1" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="3,0,12,0" VerticalAlignment="Center" Foreground="#50627E" FontWeight="SemiBold" Text="扫描目录" />
                <Grid Grid.Column="1">
                    <TextBox x:Name="RootPathTextBox"
                             Height="38"
                             Padding="10,7"
                             VerticalContentAlignment="Center"
                             Background="#F8FAFD"
                             BorderBrush="#DCE4EF"
                             BorderThickness="1"
                             Cursor="Hand"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="13"
                             IsReadOnly="True"
                             PreviewMouseLeftButtonDown="RootPathTextBox_PreviewMouseLeftButtonDown" />
                    <TextBlock Margin="11,0"
                               VerticalAlignment="Center"
                               Foreground="#8A98AC"
                               IsHitTestVisible="False"
                               Text="待选择，点击选择扫描目录">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=RootPathTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button x:Name="ScanButton" Grid.Column="2" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}" Content="开始扫描" Click="ScanButton_Click" />
                <Button x:Name="CancelButton" Grid.Column="3" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Content="取消" Click="CancelButton_Click" IsEnabled="False" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="24,16,12,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="总占用空间" />
                    <TextBlock x:Name="TotalSizeText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="目录数量" />
                    <TextBlock x:Name="DirectoryCountText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="文件数量" />
                    <TextBlock x:Name="FileCountText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="扫描耗时" />
                    <TextBlock x:Name="ElapsedText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="24,0" Background="White" BorderBrush="#E1E7EF" BorderThickness="1" CornerRadius="10">
            <Grid>
                <DataGrid x:Name="DirectoryGrid"
                          ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          Background="White"
                          BorderThickness="0"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          CellStyle="{StaticResource GridCell}"
                          ColumnHeaderStyle="{StaticResource GridHeader}"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          RowStyle="{StaticResource GridRow}"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          ContextMenuOpening="DirectoryGrid_ContextMenuOpening"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.ContextMenu>
                        <ContextMenu Style="{StaticResource RowContextMenu}">
                            <MenuItem Header="在资源管理器中显示"
                                      Click="ShowInExplorerMenuItem_Click"
                                      Style="{StaticResource RowContextMenuItem}">
                                <MenuItem.Icon>
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="#5279AE"
                                                  Data="M19,19 L5,19 5,5 12,5 12,3 5,3 C3.9,3 3,3.9 3,5 L3,19 C3,20.1 3.9,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,12 19,12 Z M14,3 L14,5 17.59,5 8.76,13.83 10.17,15.24 19,6.41 19,10 21,10 21,3 Z" />
                                        </Canvas>
                                    </Viewbox>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator Margin="5,3" Background="#E6EBF2" />
                            <MenuItem Header="移到回收站"
                                      Click="MoveToRecycleBinMenuItem_Click"
                                      Foreground="#C73E3E"
                                      Style="{StaticResource RowContextMenuItem}">
                                <MenuItem.Icon>
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="#C73E3E"
                                                  Data="M9,3 L15,3 16,5 21,5 21,7 19,7 19,20 C19,21.1 18.1,22 17,22 L7,22 C5.9,22 5,21.1 5,20 L5,7 3,7 3,5 8,5 Z M7,7 L7,20 17,20 17,7 Z M9,9 L11,9 11,18 9,18 Z M13,9 L15,9 15,18 13,18 Z" />
                                        </Canvas>
                                    </Viewbox>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="名称" Width="*" MinWidth="260">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,0,8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="35" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="{Binding IndentWidth}" />
                                        <Button Grid.Column="1"
                                                Width="16"
                                                Height="20"
                                                Padding="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="ExpanderButton_Click"
                                                Content="{Binding ExpanderGlyph}"
                                                Cursor="Hand"
                                                FontSize="9"
                                                Foreground="#52647D"
                                                Visibility="{Binding HasChildren, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Grid Grid.Column="2" Width="30" Height="26" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Viewbox Width="23" Height="23" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Viewbox.Style>
                                                    <Style TargetType="Viewbox">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Node.IsDirectory}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Viewbox.Style>
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="#E6A325"
                                                          Data="M3,4 L9,4 11,6 21,6 C22.1,6 23,6.9 23,8 L23,18 C23,19.1 22.1,20 21,20 L3,20 C1.9,20 1,19.1 1,18 L1,6 C1,4.9 1.9,4 3,4 Z" />
                                                </Canvas>
                                            </Viewbox>
                                            <Viewbox Width="22" Height="22" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Viewbox.Style>
                                                    <Style TargetType="Viewbox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Node.IsDirectory}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Viewbox.Style>
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="#5279AE"
                                                          Data="M6,2 L14,2 20,8 20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 L4,4 C4,2.9 4.9,2 6,2 Z" />
                                                    <Path Fill="#E7F0FC" Data="M14,2 L20,8 14,8 Z" />
                                                </Canvas>
                                            </Viewbox>
                                            <Border Width="15"
                                                    Height="15"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Background="#2F6FED"
                                                    BorderBrush="White"
                                                    BorderThickness="1.5"
                                                    CornerRadius="8"
                                                    Visibility="{Binding Node.IsLink, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Viewbox Width="9" Height="9">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="White"
                                                              Data="M5,17.59 L15.59,7 9,7 9,5 19,5 19,15 17,15 17,8.41 6.41,19 Z" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Column="3"
                                                   VerticalAlignment="Center"
                                                   Foreground="#1D2B45"
                                                   Text="{Binding Node.Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Node.FullPath}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="大小" Width="132" HeaderStyle="{StaticResource RightGridHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="8,0,12,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontFamily="Cascadia Mono, Consolas"
                                               Foreground="#24344F"
                                               Text="{Binding Node.SizeBytes, Converter={StaticResource ByteSizeConverter}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="占总目录比例" Width="176" HeaderStyle="{StaticResource CenterGridHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="16,0">
                                        <ProgressBar Height="7"
                                                     VerticalAlignment="Center"
                                                     Maximum="100"
                                                     Value="{Binding PercentOfRoot, Mode=OneWay}"
                                                     Foreground="#4F82EA"
                                                     Background="#E8EEF8"
                                                     BorderThickness="0" />
                                        <TextBlock Margin="0,0,2,18"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="#66758C"
                                                   Text="{Binding PercentOfRoot, StringFormat={}{0:N2}%}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="修改时间" Width="158" HeaderStyle="{StaticResource RightGridHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="8,0,12,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="#66758C"
                                               Text="{Binding Node.LastWriteTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="#9EADC1" Text="&#xE9D9;" />
                    <TextBlock Margin="0,13,0,0" Foreground="#5D6E86" FontSize="15" FontWeight="SemiBold" Text="等待扫描目录" />
                    <TextBlock Margin="0,5,0,0" Foreground="#8A97A9" Text="扫描完成后，点击箭头展开目录和文件" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="24,13,24,17">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ScanProgressBar" Width="120" Height="5" VerticalAlignment="Center" IsIndeterminate="True" Visibility="Collapsed" />
            <TextBlock x:Name="StatusText" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" Foreground="#64738A" Text="就绪" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="SkippedText" Grid.Column="2" VerticalAlignment="Center" Foreground="#8A6870" />
        </Grid>
    </Grid>
</Window>
