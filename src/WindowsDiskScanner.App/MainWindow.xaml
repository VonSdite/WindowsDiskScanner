<Window x:Class="WindowsDiskScanner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowsDiskScanner.App"
        xmlns:core="clr-namespace:WindowsDiskScanner.Core;assembly=WindowsDiskScanner.Core"
        Title="Windows 磁盘空间扫描器"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        Background="#F3F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <local:ByteSizeConverter x:Key="ByteSizeConverter" />
        <local:NodeIconConverter x:Key="NodeIconConverter" />
        <local:AccessOpacityConverter x:Key="AccessOpacityConverter" />

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2F6FED" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#225DCE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E9EFFA" />
            <Setter Property="Foreground" Value="#244777" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="BorderBrush" Value="#E5EAF1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="1" />
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type core:ScanNode}" ItemsSource="{Binding Children}">
            <Grid Height="38" Opacity="{Binding IsAccessible, Converter={StaticResource AccessOpacityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="132" />
                    <ColumnDefinition Width="176" />
                    <ColumnDefinition Width="158" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Width="23"
                               Margin="2,0,5,0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="#E6A325"
                               Text="{Binding IsDirectory, Converter={StaticResource NodeIconConverter}}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#1D2B45"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding FullPath}" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontFamily="Cascadia Mono, Consolas"
                           Foreground="#24344F"
                           Text="{Binding SizeBytes, Converter={StaticResource ByteSizeConverter}}" />

                <Grid Grid.Column="2" Margin="16,0">
                    <ProgressBar Height="7"
                                 VerticalAlignment="Center"
                                 Maximum="100"
                                 Value="{Binding PercentOfRoot}"
                                 Foreground="#4F82EA"
                                 Background="#E8EEF8"
                                 BorderThickness="0" />
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,2,18"
                               FontSize="10"
                               Foreground="#66758C"
                               Text="{Binding PercentOfRoot, StringFormat={}{0:N2}%}" />
                </Grid>

                <TextBlock Grid.Column="3"
                           Margin="8,0,12,0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="#66758C"
                           Text="{Binding LastWriteTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
            </Grid>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#14233C" Padding="28,21">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="White" FontSize="24" FontWeight="SemiBold" Text="Windows 磁盘空间扫描器" />
                    <TextBlock Margin="0,5,0,0" Foreground="#AFC2E2" Text="快速定位系统目录中的空间占用" />
                </StackPanel>
                <Border Grid.Column="1" Padding="11,7" Background="#213758" CornerRadius="18" VerticalAlignment="Center">
                    <TextBlock Foreground="#C8D7EE" FontSize="12" Text="本地扫描 · 数据不离开设备" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="24,20,24,0" Padding="14" Background="White" BorderBrush="#E3E9F1" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="3,0,12,0" VerticalAlignment="Center" Foreground="#50627E" FontWeight="SemiBold" Text="扫描目录" />
                <TextBox x:Name="RootPathTextBox"
                         Grid.Column="1"
                         Height="38"
                         Padding="10,7"
                         VerticalContentAlignment="Center"
                         Background="#F8FAFD"
                         BorderBrush="#DCE4EF"
                         BorderThickness="1"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="13" />
                <Button x:Name="BrowseButton" Grid.Column="2" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Content="浏览" Click="BrowseButton_Click" />
                <Button x:Name="ScanButton" Grid.Column="3" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}" Content="开始扫描" Click="ScanButton_Click" />
                <Button x:Name="CancelButton" Grid.Column="4" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Content="取消" Click="CancelButton_Click" IsEnabled="False" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="24,16,12,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="总占用空间" />
                    <TextBlock x:Name="TotalSizeText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="目录数量" />
                    <TextBlock x:Name="DirectoryCountText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="文件数量" />
                    <TextBlock x:Name="FileCountText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Foreground="#738198" FontSize="12" Text="扫描耗时" />
                    <TextBlock x:Name="ElapsedText" Margin="0,4,0,0" Foreground="#172742" FontSize="20" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="24,0" Background="White" BorderBrush="#E1E7EF" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="43" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#F7F9FC" BorderBrush="#E4E9F0" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                    <Grid Margin="34,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="132" />
                            <ColumnDefinition Width="176" />
                            <ColumnDefinition Width="158" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Foreground="#697991" FontWeight="SemiBold" Text="名称" />
                        <TextBlock Grid.Column="1" Margin="8,0" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#697991" FontWeight="SemiBold" Text="大小" />
                        <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#697991" FontWeight="SemiBold" Text="占总目录比例" />
                        <TextBlock Grid.Column="3" Margin="8,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#697991" FontWeight="SemiBold" Text="修改时间" />
                    </Grid>
                </Border>

                <TreeView x:Name="DirectoryTree"
                          Grid.Row="1"
                          Margin="8"
                          Padding="4"
                          ItemsSource="{Binding RootItems}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling" />

                <StackPanel x:Name="EmptyState" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="#9EADC1" Text="&#xE9D9;" />
                    <TextBlock Margin="0,13,0,0" Foreground="#5D6E86" FontSize="15" FontWeight="SemiBold" Text="等待扫描目录" />
                    <TextBlock Margin="0,5,0,0" Foreground="#8A97A9" Text="扫描完成后，点击箭头展开目录和文件" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="24,13,24,17">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ScanProgressBar" Width="120" Height="5" VerticalAlignment="Center" IsIndeterminate="True" Visibility="Collapsed" />
            <TextBlock x:Name="StatusText" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" Foreground="#64738A" Text="就绪" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="SkippedText" Grid.Column="2" VerticalAlignment="Center" Foreground="#8A6870" />
        </Grid>
    </Grid>
</Window>
