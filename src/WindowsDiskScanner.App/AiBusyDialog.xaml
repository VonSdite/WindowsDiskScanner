<Window x:Class="WindowsDiskScanner.App.AiBusyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 请求处理中"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Border Margin="12"
            Background="#F3F6FA"
            BorderBrush="#D8E0EB"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" Opacity="0.24" ShadowDepth="3" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="20,14"
                    Background="#14233C"
                    CornerRadius="11,11,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Text="AI 请求处理中" />
                    <Button Grid.Column="1"
                            Width="30"
                            Height="30"
                            Padding="0"
                            Background="#243A5B"
                            Content="×"
                            Click="CloseButton_Click"
                            Style="{StaticResource AppButton}" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="18,18,18,0" Padding="20" Style="{StaticResource AppCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="32"
                            Height="32"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#E8F0FD"
                            CornerRadius="16">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#2F6FED"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Text="i" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Foreground="#172742"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="当前已有一个 AI 请求正在处理。" />
                        <TextBlock Margin="0,9,0,0"
                                   Foreground="#64748B"
                                   LineHeight="21"
                                   Text="程序一次只处理一个 AI 请求。请等待当前请求完成或取消当前请求后再试。"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Padding="18" Background="#F3F6FA" CornerRadius="0,0,11,11">
                <Button HorizontalAlignment="Right"
                        Content="知道了"
                        IsCancel="True"
                        IsDefault="True"
                        Click="CloseButton_Click"
                        Style="{StaticResource AppPrimaryButton}" />
            </Border>
        </Grid>
    </Border>
</Window>
