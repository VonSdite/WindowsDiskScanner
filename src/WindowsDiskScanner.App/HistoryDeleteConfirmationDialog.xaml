<Window x:Class="WindowsDiskScanner.App.HistoryDeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="删除历史记录"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Border Margin="12"
            Background="#F3F6FA"
            BorderBrush="#D8E0EB"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" Opacity="0.24" ShadowDepth="3" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="20,14"
                    Background="#14233C"
                    CornerRadius="11,11,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="17" FontWeight="SemiBold" Text="删除历史记录" />
                    <Button Grid.Column="1"
                            Width="30"
                            Height="30"
                            Padding="0"
                            Background="#243A5B"
                            Content="×"
                            Click="CancelButton_Click"
                            Style="{StaticResource AppButton}" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="18,18,18,0" Padding="20" Style="{StaticResource AppCard}">
                <StackPanel>
                    <TextBlock x:Name="PromptText" Foreground="#172742" FontSize="15" FontWeight="SemiBold" />
                    <Border Margin="0,14,0,0" Padding="13,11" Background="#F7F9FC" BorderBrush="#E3E9F1" BorderThickness="1" CornerRadius="7">
                        <TextBlock x:Name="RecordText"
                                   MaxHeight="180"
                                   Foreground="#5F6F87"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />
                    </Border>
                    <TextBlock Margin="0,12,0,0" Foreground="#9A5A5A" Text="删除后无法恢复。" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Padding="18" Background="#F3F6FA" CornerRadius="0,0,11,11">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Margin="0,0,10,0" Content="取消" IsCancel="True" Click="CancelButton_Click" Style="{StaticResource AppButton}" />
                    <Button Content="删除" Click="ConfirmButton_Click" Style="{StaticResource AppDangerButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
