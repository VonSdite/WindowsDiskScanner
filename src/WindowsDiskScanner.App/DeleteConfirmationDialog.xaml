<Window x:Class="WindowsDiskScanner.App.DeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="移到回收站"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Background" Value="#E9EFFA" />
            <Setter Property="Foreground" Value="#244777" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#D14343" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C8D7EE" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background" Value="#284164" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="#F3F6FA"
            BorderBrush="#D8E0EB"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" Opacity="0.24" ShadowDepth="3" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="20,14"
                    Background="#14233C"
                    CornerRadius="11,11,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Text="移到回收站" />
                    <Button Grid.Column="1"
                            Content="×"
                            Click="CancelButton_Click"
                            Style="{StaticResource CloseButton}" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="18,18,18,0"
                    Padding="20"
                    Background="White"
                    BorderBrush="#E1E7EF"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock x:Name="PromptText"
                               Foreground="#172742"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <Border Margin="0,14,0,0"
                            Padding="13,11"
                            Background="#F7F9FC"
                            BorderBrush="#E3E9F1"
                            BorderThickness="1"
                            CornerRadius="7">
                        <TextBlock x:Name="PathText"
                                   MaxHeight="180"
                                   Foreground="#5F6F87"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Padding="18" Background="#F3F6FA" CornerRadius="0,0,11,11">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Margin="0,0,10,0"
                            Content="取消"
                            IsCancel="True"
                            IsDefault="True"
                            Click="CancelButton_Click"
                            Style="{StaticResource DialogButton}" />
                    <Button Content="移到回收站"
                            Click="ConfirmButton_Click"
                            Style="{StaticResource DeleteButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
